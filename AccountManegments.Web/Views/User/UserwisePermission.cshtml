@inject IHttpContextAccessor Accessor;
@inject UserSession _userSession

@{
    ViewData["Title"] = "UserwisePermission";
    Layout = "~/Views/Shared/Main_Layout.cshtml";
}

<div class=" radius-10 w-100">
    <div class="my-3 border-bottom"></div>
    <div class="row">
        <div class="col-12 col-lg-3 col-md-3 col-xl-3">
            <div class="card radius-10 w-100">
                <div class="card-body">
                    <div class="row w-100 ac-view-list card radius-10 w-100">
                        <div class="row ">
                            <div class="col-12">
                            </div>
                        </div>
                        <div class="card-body">
                            <h5 class="mb-0 mt-4" id="PermissionsInfoHeading">User List</h5>
                            <hr>
                            <div class="table-responsive">
                                <table class="table align-middle mb-0">
                                    <thead class="table-light btn-primary">
                                        <tr>
                                            <th>User</th>
                                            <th>Edit</th>
                                        </tr>
                                    </thead>
                                    <tbody id="UserwisePermissiontbody">
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-9 col-xl-9 ac-detail hide-sm">
            <div class="card radius-10">
                <div class="card-body">
                    <h5 class="mb-0 mt-4" id="PermissionsInfoHeading">User Permissions</h5>
                    <hr>
                    <div class="row g-3 ac-detail d-none" id="groupDetailsInfo">
                        <div class="table-responsive">
                            <div class="tab-content" id="pills-tabContent">
                                <div class="tab-pane fade show active" id="credit-card" role="tabpanel">
                                    <div class="p-3">
                                        <table class="table table-bordered table-hover" style="width: 1050px;">
                                            <thead class="table-light btn-primary">
                                                <tr>
                                                    <th>Form Permission</th>
                                                    <th>
                                                        View Permission
                                                        <div class="form-check">
                                                            <input class="form-check-input alluser-checkbox" type="checkbox" onclick="toggleColumnCheckboxes(this, 'isView-column')">
                                                        </div>
                                                    </th>
                                                    <th>
                                                        Add Permission
                                                        <div class="form-check">
                                                            <input class="form-check-input alluser-checkbox" type="checkbox" onclick="toggleColumnCheckboxes(this, 'isAdd-column')">
                                                        </div>
                                                    </th>
                                                    <th>
                                                        Edit Permission
                                                        <div class="form-check">
                                                            <input class="form-check-input alluser-checkbox" type="checkbox" onclick="toggleColumnCheckboxes(this, 'isEdit-column')">
                                                        </div>
                                                    </th>
                                                    <th>
                                                        Delete Permission
                                                        <div class="form-check">
                                                            <input class="form-check-input alluser-checkbox" type="checkbox" onclick="toggleColumnCheckboxes(this, 'isDelete-column')">
                                                        </div>
                                                    </th>
                                                    <th>
                                                        AutoApproved Permission
                                                        <div class="form-check">
                                                            <input class="form-check-input alluser-checkbox" type="checkbox" onclick="toggleColumnCheckboxes(this, 'isApproved-column')">
                                                        </div>
                                                    </th>
                                                    <th class="text-center">
                                                        All
                                                        <div class="form-check">
                                                            <input class="form-check-input" type="checkbox" id="userRoleCheckboxAll" onclick="userRoleAllCheckboxes(this)">
                                                        </div>
                                                    </th>
                                                </tr>
                                            </thead>

                                            <tbody id="dvEditUserPermissionForm">
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12">
                            <button type="button" class="btn btn-lg btn-success col-lg" onclick="UpdateUserwiseFormPermission()" id="btnUserwiseForm">Update</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/moduls/userwiseformpermissionscript.js"></script>
}