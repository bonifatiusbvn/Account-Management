@inject IHttpContextAccessor Accessor;
@inject UserSession _userSession

@{
    ViewData["Title"] = "UserwisePermission";
    Layout = "~/Views/Shared/Main_Layout.cshtml";
}


<div class="">
    <div class="">
        <div class=" radius-10 w-100">
            <div class="my-3 border-bottom"></div>
            <div class="">
                <div class="row">
                    <div class="col-12 col-lg-7 col-md-7 col-xl-7">
                        <div class="card radius-10 w-100">
                            <div class="card-body">
                                <div class="row w-100 ac-view-list card radius-10 w-100">
                                    <div class="row ">
                                        <div class="col-12">
                                        </div>
                                    </div>

                                    <div class="card-body">
                                        <div class="table-responsive">
                                            <table class="table align-middle mb-0">
                                                <thead class="table-light btn-primary">
                                                    <tr>
                                                        <th>User</th>
                                                        <th>Active</th>
                                                        <th>Site</th>
                                                        <th>Action</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="UserwisePermissiontbody">
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                    <div class="col-12 col-lg-5 col-xl-5 ac-detail hide-sm">
                        <div class="card radius-10">
                            <div class="card-body" style="height:658px;">
                                <h5 class="mb-0 mt-4" id="GroupInfoHeading">Group Information</h5>
                                <hr>
                                <div class="row g-3 ac-detail d-none" id="groupDetailsInfo">

                                    <div class="col-12">
                                        <label class="form-label">Site Name</label>
                                        <textarea id="dspSite" class="form-control" style="height:80px;" readonly>
                            </textarea>
                                    </div>


                                </div>
                                <div id="addgroupinfo" class="card d-none">
                                    <form id="AddSiteGroupForm">
                                        <div class="card-body">
                                            <div class="row">
                                                <div class="col-md-12 mb-3">
                                                    <label class="form-label">Select Site</label>
                                                    <select class="multiple-select form-select" id="textGroupSiteList" name="textGroupSiteList" multiple="multiple" style="width: 100%;">
                                                    </select>
                                                </div>
                                                <div class="col-md-12 mb-3">
                                                    <textarea id="SelectedSite" class="form-control" style="height:80px;" readonly></textarea>
                                                    <textarea id="SelectedSiteID" class="form-control" style="height:80px;" hidden></textarea>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-primary" onclick="AddSiteGroupDetails()" id="addsitegroupbtn">Save</button>
                                            <button type="button" class="btn btn-primary" onclick="UpdateSiteGroupDetails()" id="updatesitegroupbtn" style="display:none;">Update</button>
                                        </div>
                                    </form>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="offcanvas offcanvas-end border-0 w-25 ac-add-edit" tabindex="-1" id="createFormGroup">
        <div class="d-flex align-items-center bg-primary bg-gradient p-3 offcanvas-header">
            <h5 class="m-0 me-2 text-white">Update Userwise Form Permission</h5>

            <button type="button" class="btn-close btn-close-white ms-auto" id="customizerclose-btn" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body p-0">
            <div data-simplebar class="h-100">
                <div class="p-4">
                    <div>
                        <div>
                            <form class="row g-3" id="userForm">
                                <!---Partial View--->
                                <div class="col-12" id="dvEditUserPermissionForm"></div>
                                <div class="col-12">
                                    <button type="button" class="btn btn-lg btn-success col-lg-12" onclick="UpdateUserwiseFormPermission()" id="btnUserwiseForm">Update</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/moduls/userwiseformpermissionscript.js"></script>
}