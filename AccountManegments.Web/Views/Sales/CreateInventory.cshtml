@using AccountManegments.Web.Models;
@inject IHttpContextAccessor Accessor;
@inject UserSession _userSession
@{
    ViewData["Title"] = "CreateInventory";
    Layout = "~/Views/Shared/Main_Layout.cshtml";
}


<style>
    .error-border {
        border: 2px solid red;
    }

    label.failed {
        color: red;
    }

    .table tbody tr {
        border-bottom: 1px solid #ddd;
        height: 50px;
    }

    .table tbody td {
        vertical-align: middle;
        padding: 5px;
    }
</style>

@section HeaderButton {

    @if (UserSession.FormPermisionData.Any(a => a.FormName == "Purchase Request" && (a.Add == true)))
    {
        <button type="button" class="btn btn-primary fixed-button" onclick="clearCreatetxtInventoryText()"><i class="lni lni-circle-plus"></i>Purchase Request</button>
    }
}

<div class="">
    <div class="">
        <div class=" radius-10 w-100">
            <div class="my-3 border-bottom"></div>
            <div class="">
                <div class="row">
                    <div class="col-12 col-lg-7 col-md-7 col-xl-7">
                        <div class="card radius-10 w-100">
                            <div class="card-body" style="height:700px;">
                                <div class="row w-100 ac-view-list card radius-10 w-100">
                                    <div class="row ">
                                        <div class="col-12">
                                            <div class="card-body">
                                                <div class="row g-3">
                                                    <div class="col-12 col-lg-4">
                                                        <input class="form-control" id="txtInventoryRequestSearch" onkeyup="filterInventoryRequestTable()" placeholder="Search" />
                                                    </div>
                                                    <div class="col-12 col-lg-4">
                                                        <select class="form-select" id="InventoryRequestSearchBy" onchange="filterInventoryRequestTable()">
                                                            <option selected="selected">All</option>
                                                            <option>ItemName</option>
                                                            <option>UnitName</option>
                                                        </select>
                                                        <input type="hidden" id="textsiteId" value="@UserSession.SiteId" />
                                                    </div>
                                                    <div class="col-12 col-lg-4">
                                                        <select class="form-select" id="InventoryRequestSortBy" onchange="sortInventoryRequestTable()">
                                                            <option value="DescendingCreatedOn" selected="selected">Most Recent</option>
                                                            <option value="AscendingCreatedOn">First Created</option>
                                                            <option value="AscendingItem">ItemName(A-Z)</option>
                                                            <option value="DescendingItem">ItemName(Z-A)</option>
                                                        </select>
                                                    </div>
                                                </div><!--end row-->
                                            </div>
                                        </div>
                                    </div>
                                    <div class="card-body">
                                        <div class="table-responsive">
                                            <table class="table align-middle mb-0">
                                                <thead class="table-light btn-primary">
                                                    <tr>
                                                        <th>Item Name</th>
                                                        <th>Date</th>
                                                        <th>Unit</th>
                                                        <th>Quantity</th>
                                                        <th>Approve</th>
                                                        @if (UserSession.FormPermisionData.Any(a => a.FormName == "Purchase Request" && (a.Edit == true || a.Delete == true)))
                                                        {
                                                            <th>Action</th>
                                                        }
                                                    </tr>
                                                </thead>
                                                <tbody id="Inventorybody">
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!--end row-->
                    </div>
                    <div class="col-12 col-lg-5 col-xl-5 ac-detail hide-sm">
                        <div class="card radius-10">
                            <div class="card-body" style="height:700px;">
                                <h5 class="mb-0 mt-4" id="Inventoryheadingtext"></h5>
                                <hr>
                                <div class="row g-3 ac-detail d-none" id="InventoryInfo">
                                    <div class="col-12">
                                        <label class="form-label">Purchase Request No</label>
                                        <input type="text" class="form-control" id="dspPrNo" readonly>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">Item Name</label>
                                        <input type="text" class="form-control" id="dspItem" readonly>
                                        <input type="hidden" class="form-control" id="dspPId" readonly>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">Item Description</label>
                                        <input type="text" class="form-control" id="dspItemDescription" readonly>
                                        <input type="hidden" class="form-control" id="dspPId" readonly>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">Unit Name</label>
                                        <input type="text" class="form-control" id="dspUnitName" readonly>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">Quantity</label>
                                        <input type="text" class="form-control" id="dspQuantity" readonly>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">SiteName</label>
                                        <input type="text" class="form-control" id="dspSiteName" readonly>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">IsApproved</label>
                                        <div class="form-check form-switch mb-3">
                                            <input class="form-check-input font-22" id="dspIsApproved" type="checkbox" style="margin-left:-35px;" disabled>
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">Site Address</label>
                                        <textarea type="text" class="form-control" row="3" id="dspPrSiteAddress" style="height: 92px;" readonly></textarea>
                                    </div>
                                </div>

                                <div id="addInventoryInfo">
                                    <form class="row g-3" id="InventoryForm" enctype="multipart/form-data">
                                        <div class="col-lg-6 col-12">
                                            <label class="form-label">Product Names</label>
                                            <input type="text" id="searchInventoryItemnameInput" name="searchInventoryItemnameInput" placeholder="Product Names" class="form-control">
                                            <input type="hidden" id="txtInventoryItemName" name="txtItemName">
                                            <span id="searchItemnameInput" class="text-danger"></span>
                                            <input type="hidden" id="txtInventoryCreatedBy" value="@_userSession.UserId" />
                                        </div>
                                        <div class="col-lg-6 col-12">
                                            <label class="form-label">Date</label>
                                            <input type="date" id="txtInventoryPrdate" name="txtInventoryPrdate" class="form-control">
                                            <span id="spnPrdate" class="text-danger"></span>
                                        </div>
                                        <div class="col-lg-12 col-12">
                                            <label class="form-label">Product Description</label>
                                            <textarea id="PRInventoryItemDescription" name="PRInventoryItemDescription" placeholder="Product Description" class="form-control" style="height: 50px;"></textarea>
                                        </div>
                                        <div class="col-lg-6 col-12">
                                            <label class="form-label">Unit Type</label>
                                            <input type="text" id="txtInventoryUnitType" name="txtInventoryUnitType" placeholder="Unit Type" class="form-control">
                                            <span id="spnUnitType" class="text-danger"></span>
                                        </div>
                                        <input type="hidden" id="txtInventoryUnitTypeHidden" name="txtInventoryUnitTypeHidden">
                                        <div class="col-lg-6 col-12">
                                            <label class="form-label">Quantity</label>
                                            <input type="number" class="form-control form-control" placeholder="Quantity" id="txtInventoryQuantity" name="txtInventoryQuantity" value="1" min="1" oninput="preventEmptyValue(this)">
                                            <span id="spnQuantity" class="text-danger"></span>
                                        </div>
                                        <div class="col-12">
                                            <button type="button" class="btn btn-primary" onclick="CreateInventory()" id="addbtnInventory" style="margin-top: 5px; margin-left:557px;">Save</button>
                                            <button type="button" class="btn btn-primary" onclick="UpdateInventoryDetails()" id="updatebtnInventory" style="display:none;margin-top: 5px;margin-left:540px;">Update</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script type="text/javascript">
    document.addEventListener("DOMContentLoaded", function () {
        const today = new Date().toISOString().split('T')[0]; // Format as YYYY-MM-DD
        document.getElementById("txtInventoryPrdate").value = today;
    });
</script>
@section Scripts {
    <script src="~/moduls/inventoryscript.js" asp-append-version="true"></script>
}
