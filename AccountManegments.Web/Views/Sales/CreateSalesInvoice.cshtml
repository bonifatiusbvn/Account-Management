                                            </div>
                                            <!--end row-->
                                            <div class="card">
                                                <div class="card-body">
                                                    <div class="hstack gap-2 justify-content-end d-print-none mt-4">
                                                        @if (Model.Id == Guid.Empty)
                                                        {
                                                            <button type="button" class="btn btn-lg btn-primary px-5" id="SaveSalesInvoiceOButton" onclick="InsertSalesInvoiceDetails()"><i class="ri-printer-line align-bottom me-1"></i>Create Invoice</button>
                                                        }
                                                        else
                                                        {
                                                            <button type="button" class="btn btn-lg btn-primary px-5" id="UpdateInvoiceOButton" onclick="UpdateSalesInvoiceDetails()"><i class="ri-printer-line align-bottom me-1"></i>Update Invoice</button>
