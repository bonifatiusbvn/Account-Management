@model AccountManagement.DBContext.Models.ViewModels.SalesMaster.SalesInvoiceMasterModel
@using AccountManegments.Web.Models;
@inject IHttpContextAccessor Accessor;
@inject UserSession _userSession
@{
    ViewData["Title"] = "CreateSalesInvoice";
    Layout = "~/Views/Shared/Main_Layout.cshtml";
}

<style>
    #SalespaymentStatus-error, #textSalesSupplierName-error, #textSalesCompanyName-error, #textSalesSupplierMobile-error {
        color: red;
    }

    label.error {
        color: red;
    }

    .disabled {
        opacity: 0.5;
        pointer-events: none;
    }
</style>
@{
    var usercompany = UserSession.CompanyData;
    var selectedcompanyId = UserSession.ComapnyId;
    var usercompanyCount = (usercompany != null) ? usercompany.Count : 0;
}
<input type="hidden" id="Salescreatedbyid" value="@_userSession.UserId" />
<input type="hidden" id="txtSalessessionSiteName" value="@UserSession.SiteId" />
<input type="hidden" id="txtSalesSiteName" value="@Model.SiteId" />
<input type="hidden" id="txtSalesId" value="@Model.Id" />
<div class="">
    <div class="">
        <div class="radius-10 w-100">
            <div class="my-3 border-bottom"></div>
            <div class="">
                <div class="row">
                    <div class="col-lg-12">
                        <div class="" id="invoiceSupplierList">
                            <form id="CreateSalesInvoiceForm">
                                <div class="">
                                    <div>
                                        <div class="row justify-content-center">
                                            <div class="col-xxl-12">
                                                <div class="">
                                                    <div class="border-bottom border-bottom-dashed">
                                                        <div class="row">
                                                            <div class="col-6 col-lg-6">
                                                                <div class="card">
                                                                    <div class="card-header">
                                                                        <div class="row align-items-center">
                                                                            <div class="col">
                                                                                <h6 class="mb-0">Invoice Details</h6>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="card-body">
                                                                        <div class="row">
                                                                            <div class="col-md-4">
                                                                                <div>
                                                                                    <label for="textSalesCompanyName" class="form-label">Company Name</label>
                                                                                </div>
                                                                                <div class="ms-auto">
                                                                                    <select class="form-select" id="textSalesCompanyName" name="textSalesCompanyName">
                                                                                        @if (Model.CompanyName != null)
                                                                                        {
                                                                                            <option selected value="@Model.CompanyId">@Model.CompanyName</option>
                                                                                        }
                                                                                        else if (usercompany != null && usercompany.Any())
                                                                                        {
                                                                                            foreach (var company in usercompany)
                                                                                            {
                                                                                                var isSelect = company.CompanyId.ToString().Equals(selectedcompanyId, StringComparison.OrdinalIgnoreCase) ? "selected" : "";
                                                                                                <option value="@company.CompanyId" (isSelect)>@company.CompanyName</option>
                                                                                            }
                                                                                        }
                                                                                        else
                                                                                        {
                                                                                            <option selected value="" disabled>Select Company</option>
                                                                                        }
                                                                                    </select>
                                                                                </div>
                                                                            </div>
                                                                            <div class="col-5 col-lg-5">
                                                                                <label for="SalesSupplierInvoiceNo" class="form-label">Invoice No</label>
                                                                                <input type="text" class="form-control" id="textSalesInvoicePrefix" value="@Model.SalesInvoiceNo" readonly />
                                                                            </div>
                                                                            <div class="col-3 col-lg-3">
                                                                                <label for="textSalesOrderDate" class="form-label">Date</label>
                                                                                @{
                                                                                    DateTime invoiceDate = Model.Date ?? DateTime.Now;
                                                                                    string formattedDate = invoiceDate.ToString("yyyy-MM-dd");
                                                                                }
                                                                                <input type="date" id="textSalesOrderDate" class="form-control" value="@formattedDate">
                                                                            </div>
                                                                        </div>
                                                                        <div class="row mt-3">
                                                                            <div class="col-6 col-lg-6">
                                                                                <label for="textSalescompanybillingaddress" class="form-label">Billing Address</label>
                                                                                <input type="text" id="textSalesCompanyBillingAddress" value="@Model.CompanyFullAddress" class="form-control" placeholder="Billing Address" readonly />
                                                                            </div>
                                                                            <div class="col-6 col-lg-6">
                                                                                <label for="textSalesCompanyGstNo" class="form-label">GST NO</label>
                                                                                <input type="text" id="textSalesCompanyGstNo" value="@Model.CompanyGstNo" class="form-control" placeholder="GST No" readonly />
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <div class="col-6 col-lg-6">
                                                                <div class="card">
                                                                    <div class="card-header">
                                                                        <div class="row align-items-center">
                                                                            <div class="col">
                                                                                <h6 class="mb-0">Customer Details</h6>
                                                                            </div>
                                                                            <div class="col" style="padding-left: 400px;">
                                                                                @if (Model.InvoiceType != null)
                                                                                {
                                                                                    <select class="form-control form-select valid" id="ddlSalesinvoicetype" name="ddlSalesinvoicetype">
                                                                                        <option value="@Model.InvoiceType" selected>@Model.InvoiceType</option>
                                                                                        @if (@Model.InvoiceType == "Sales")
                                                                                        {
                                                                                            <option value="Sales Return">Sales Return</option>
                                                                                            <option value="Credit Note">Credit Note</option>
                                                                                        }
                                                                                        @if (@Model.InvoiceType == "Sales Return")
                                                                                        {
                                                                                            <option value="Sales">Sales</option>
                                                                                            <option value="Credit Note">Credit Note</option>
                                                                                        }
                                                                                        @if (@Model.InvoiceType == "Credit Note")
                                                                                        {
                                                                                            <option value="Sales">Sales</option>
                                                                                            <option value="Sales Return">Sales Return</option>
                                                                                        }
                                                                                    </select>
                                                                                }
                                                                                else
                                                                                {
                                                                                    <select class="form-control form-select valid" id="ddlSalesinvoicetype" name="ddlSalesinvoicetype">
                                                                                        <option value="Sales" selected>Sales</option>
                                                                                        <option value="Sales Return">Sales Return</option>
                                                                                        <option value="Credit Note">Credit Note</option>
                                                                                    </select>
                                                                                }
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="card-body">
                                                                        <div class="row">
                                                                            <div class="col-6 col-lg-6">
                                                                                <label for="textSalesSupplierName" class="form-label">Supplier Name</label>
                                                                                <select class="form-select" id="textSalesSupplierName" name="textSalesSupplierName">
                                                                                    @if (Model.SupplierName != null)
                                                                                    {
                                                                                        <option selected value="@Model.SupplierId">@Model.SupplierName</option>
                                                                                    }
                                                                                    else
                                                                                    {
                                                                                        <option selected disabled value="">Select Supplier</option>
                                                                                    }
                                                                                </select>
                                                                            </div>
                                                                            <div class="col-6 col-lg-6">
                                                                                <label for="textSalesSupplierMobile" class="form-label">Mobile No</label>
                                                                                <input type="text" id="textSalesSupplierMobile" name="textSalesSupplierMobile" value="@Model.SupplierMobileNo" class="form-control" placeholder="Mobile No" readonly />
                                                                            </div>
                                                                        </div>
                                                                        <div class="row mt-3">
                                                                            <div class="col-6 col-lg-6">
                                                                                <label for="textSalesSupplierAddress" class="form-label">Address</label>
                                                                                <input type="text" id="textSalesSupplierAddress" name="textSalesSupplierAddress" value="@Model.SupplierFullAddress" class="form-control" placeholder="Address" readonly />
                                                                            </div>
                                                                            <div class="col-6 col-lg-6">
                                                                                <label for="textSalesSupplierGST" class="form-label">GST NO</label>
                                                                                <input type="text" id="textSalesSupplierGST" value="@Model.SupplierGstNo" class="form-control" placeholder="GST No" readonly />
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <!---- Product Details ---->
                                                <div class="row">
                                                </div>
                                                <div class="card">
                                                    <div class="row p-3">
                                                        <h5 class="card-header">
                                                            Add Product
                                                            <a class="font-22" onclick="fn_OpenAddSalesproductmodal()">
                                                                <i class="lni lni-circle-plus"></i>
                                                            </a>
                                                            <span id="spnSalesitembutton" class="text-danger"></span>
                                                        </h5>
                                                    </div>

                                                    <div class="card-body pt-0">
                                                        <div class="table-responsive" style="height:350px">
                                                            <table class="table align-middle mb-0">
                                                                <thead class="table-light btn-primary">
                                                                    <tr class="text-uppercase">
                                                                        <th>No</th>
                                                                        <th>Product</th>
                                                                        <th>HSN</th>
                                                                        <th>Qty</th>
                                                                        <th>Qty Type</th>
                                                                        <th>Price(₹)</th>
                                                                        <th>Dis(₹)</th>
                                                                        <th>Dis(%)</th>
                                                                        <th>GST(%)</th>
                                                                        <th>GST(₹)</th>
                                                                        <th>Amount(₹)</th>
                                                                        <th></th>
                                                                    </tr>
                                                                </thead>
                                                                @if (Model.SalesItemList != null)
                                                                {
                                                                    <tbody id="addnewSalesproductlink">
                                                                        @Html.Partial("_DisplaySalesItemDetailsPartial", Model.SalesItemList)
                                                                    </tbody>
                                                                }
                                                                else
                                                                {
                                                                    <tbody id="addnewSalesproductlink">
                                                                    </tbody>
                                                                }
                                                            </table>

                                                        </div>
                                                        <div class="card-footer">
                                                            <table class="table align-middle mb-0">
                                                                <thead class="table-light btn-primary mb-0">
                                                                    <tr>
                                                                        <th>#</th>
                                                                        <th>Total</th>
                                                                        <th id="SalesTotalProductQuantity"></th>
                                                                        <th id="SalesTotalProductPrice"></th>
                                                                        <th></th>
                                                                        <th id="SalesTotalDiscountPrice"></th>
                                                                        <th></th>
                                                                        <th></th>
                                                                        <th></th>
                                                                        <th id="SalesTotalProductGST"></th>
                                                                        <th></th>
                                                                        <th id="SalesTotalProductAmount"></th>
                                                                        <th></th>
                                                                    </tr>
                                                                </thead>
                                                            </table>
                                                        </div>
                                                        <div class=" card">
                                                            <div class="row card-body">
                                                                <div class="col-lg-6 col-sm-12 ">
                                                                    <div class="row">
                                                                        <div class="col-lg-12 col-sm-12 mt-2 ">
                                                                            <div class="mb-2">
                                                                                <div class="input-group mb-3">
                                                                                    <label class="input-group-text">
                                                                                        Challan/Document No
                                                                                    </label>
                                                                                    <input type="text" class="form-control" id="txtSaleschalanNo" value="@Model.ChallanNo" name="txtSaleschalanNo" placeholder="Challan/Document No">
                                                                                </div>
                                                                                <div class="input-group mb-3">
                                                                                    <label class="input-group-text">
                                                                                        BUYERS CODE
                                                                                    </label>
                                                                                    <input type="text" class="form-control" placeholder="Buyer's Code" id="txtSaleslrNo" value="@Model.Lrno" name="txtSaleslrNo">

                                                                                </div>
                                                                                <div class="input-group mb-3">
                                                                                    <label class="input-group-text">
                                                                                        Vehicle No
                                                                                    </label>
                                                                                    <input type="text" class="form-control" placeholder="Vehicle No" id="txtSalesvehicleno" value="@Model.VehicleNo" name="txtSalesvehicleno">
                                                                                </div>
                                                                                <div class="input-group mb-3">
                                                                                    <label class="input-group-text">
                                                                                        Dispatch By
                                                                                    </label>
                                                                                    <input type="text" class="form-control" placeholder="Dispatch By" id="txtSalesdispatch" value="@Model.DispatchBy" name="txtSalesdispatch">
                                                                                </div>
                                                                                <div class="input-group mb-3">
                                                                                    <label class="input-group-text">
                                                                                        Payment Terms
                                                                                    </label>
                                                                                    <input type="text" class="form-control" placeholder="Payment Terms" id="txtSalespayment" value="@Model.PaymentTerms" name="txtSalespayment">

                                                                                </div>
                                                                                <div class="form-check form-check-inline" style="display:none">
                                                                                    <input class="form-check-input" style="margin-left:2px;" type="radio" id="SalesunpaidRadio" value="unpaid" name="SalespaymentStatus" checked>
                                                                                    <label class="form-check-label" for="SalesunpaidRadio">Unpaid</label>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>

                                                                <div class="col-lg-6 col-sm-12 ac-invoice-total">
                                                                    <div class="table">
                                                                        <table class="table table-borderless table-sm table-nowrap align-middle mb-0">
                                                                            <tbody>
                                                                                <tr>
                                                                                    <th scope="row">Sub Total</th>
                                                                                    <td style="width:150px;">
                                                                                        <input type="text" class="form-control border-0" id="Sales-cart-subtotal" placeholder="₹0.00" readonly />
                                                                                    </td>
                                                                                </tr>
                                                                                <tr>
                                                                                    <th scope="row">Total GST</th>
                                                                                    <td>
                                                                                        <input type="text" class="form-control border-0" id="Salestotalgst" value="@Model.TotalGstamount" placeholder="₹0.00" readonly />
                                                                                    </td>
                                                                                </tr>
                                                                                <tr>
                                                                                    <th scope="row">TDS <small class="text-muted"></small></th>
                                                                                    <td>
                                                                                        @if (Model.Tds != null)
                                                                                        {
                                                                                            <input type="text" class="form-control border-0" id="Sales-cart-tds" placeholder="₹0.00" value="@Model.Tds" />
                                                                                        }
                                                                                        else
                                                                                        {
                                                                                            <input type="text" class="form-control border-0" id="Sales-cart-tds" placeholder="₹0.00" />
                                                                                        }

                                                                                    </td>
                                                                                </tr>
                                                                                <tr>
                                                                                    <th scope="row">Discount <small class="text-muted"></small></th>
                                                                                    <td>
                                                                                        <input type="text" class="form-control border-0" id="Sales-cart-discount" value="@Model.TotalDiscount" placeholder="₹0.00" readonly />
                                                                                    </td>
                                                                                </tr>
                                                                                <tr class="border-top border-top-dashed">
                                                                                    <th scope="row">Adjustment</th>
                                                                                    <td>
                                                                                        @if (Model.DiscountRoundoff != null)
                                                                                        {
                                                                                            <input type="text" class="form-control border-0" id="SalesIDiscountRoundOff" value="@Model.DiscountRoundoff" placeholder="₹0.00" />
                                                                                        }
                                                                                        else
                                                                                        {
                                                                                            <input type="text" class="form-control border-0" id="SalesIDiscountRoundOff" placeholder="₹0.00" />
                                                                                        }
                                                                                    </td>
                                                                                </tr>
                                                                                <tr class="border-top border-top-dashed">
                                                                                    <th scope="row">Total Amount</th>
                                                                                    <td>
                                                                                        <input type="text" class="form-control border-0" id="Sales-cart-total" value="@Model.TotalAmount" placeholder="₹0.00" readonly />
                                                                                    </td>
                                                                                </tr>
                                                                            </tbody>
                                                                        </table>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
