@inject IHttpContextAccessor Accessor;
@inject UserSession _userSession
@{
    ViewData["Title"] = "SalesList";
    Layout = "~/Views/Shared/Main_Layout.cshtml";
}

<style>
    .table tbody tr {
        border-bottom: 1px solid #ddd;
        height: 50px;
    }

    .table tbody td {
        vertical-align: middle;
        padding: 5px;
    }
</style>
<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="d-flex align-items-center">
        <form class="position-relative">
            @if (UserSession.FormPermisionData.Any(a => a.FormName == "Sales Invoice" && (a.Add == true)))
            {
                                    <a type="button" class="btn btn-primary fixed-button" href="/Sales/CreateSalesInvoice"><i class="lni lni-circle-plus"></i>Create SalesInvoice</a>
            }
        </form>
    </div>
</div>
<div class="">
    <div class="">
        <div class=" radius-10 w-100">
            <div class="my-3 border-bottom"></div>
            <div class="">
                <div class="row">
                    <div class="col-12 col-lg-12 col-md-12 col-xl-12">
                        <div class="card radius-10 w-100">
                            <div class="card-body">
                                <div class="row w-100 ac-view-list card radius-10 w-100">
                                    <div class="row ">
                                        <div class="col-12">
                                            <div class="card-body">
                                                <div class="row g-3">
                                                    <div class="col-12 col-lg-4">
                                                        <input class="form-control" id="txtSupplierInvoiceSearch" onkeyup="filterSupplierInvoiceTable()" placeholder="Search">
                                                    </div>
                                                    <div class="col-12 col-lg-4">
                                                        <select class="form-select" id="ddlInvoiceCompanyName" name="ddlInvoiceCompanyName" onchange="companyfilterSupplierInvoice()">
                                                            <option selected disabled value="">Select Company</option>
                                                        </select>
                                                    </div>
                                                    <div class="col-12 col-lg-4">
                                                        <select class="form-select" id="SortBySupplierInvoice" onchange="SupplierInvoicesortTable()">
                                                            <option value="DescendingCreatedOn" selected="selected">Most Recent</option>
                                                            <option value="AscendingCreatedOn">First Created</option>
                                                            <option value="AscendingCompanyName">CompanyName (a-z)</option>
                                                            <option value="DescendingCompanyName">CompanyName (z-a)</option>
                                                        </select>
                                                    </div>
                                                </div><!--end row-->
                                            </div>
                                        </div>
                                    </div>
                                    <div class="card-body">
                                        <div class="table-responsive">
                                            <table class="table align-middle mb-0">
                                                <thead class="table-light btn-primary">
                                                    <tr>
                                                        <th>Sales InvoiceNo</th>
                                                        <th>
                                                            <a href="#" onclick="sortTable('Date')" class="white-text">Date</a>
                                                        </th>
                                                        <th>Customer</th>
                                                        <th>Company</th>
                                                        <th>Total Amount</th>
                                                        @if (UserSession.FormPermisionData.Any(a => a.FormName == "Sales Invoice" && (a.Edit == true || a.Delete == true)))
                                                        {
                                                                                <th>Action</th>
                                                        }
                                                    </tr>
                                                </thead>
                                                <tbody id="SalesInvoicebody">
                                                </tbody>
                                            </table>
                                        </div>
                                        @* <div class="col-12 text-end mt-3">
                                            <a class="btn" onclick="ExportToPDFInvoiceDetails()" style="background-color:#B31B1B;color:white;">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 1536 1792">
                                                    <path fill="currentColor" d="M1468 380q28 28 48 76t20 88v1152q0 40-28 68t-68 28H96q-40 0-68-28t-28-68V96q0-40 28-68T96 0h896q40 0 88 20t76 48zm-444-244v376h376q-10-29-22-41l-313-313q-12-12-41-22m384 1528V640H992q-40 0-68-28t-28-68V128H128v1536zm-514-593q33 26 84 56q59-7 117-7q147 0 177 49q16 22 2 52q0 1-1 2l-2 2v1q-6 38-71 38q-48 0-115-20t-130-53q-221 24-392 83q-153 262-242 262q-15 0-28-7l-24-12q-1-1-6-5q-10-10-6-36q9-40 56-91.5t132-96.5q14-9 23 6q2 2 2 4q52-85 107-197q68-136 104-262q-24-82-30.5-159.5T657 552q11-40 42-40h22q23 0 35 15q18 21 9 68q-2 6-4 8q1 3 1 8v30q-2 123-14 192q55 164 146 238m-576 411q52-24 137-158q-51 40-87.5 84t-49.5 74m398-920q-15 42-2 132q1-7 7-44q0-3 7-43q1-4 4-8q-1-1-1-2q-1-2-1-3q-1-22-13-36q0 1-1 2zm-124 661q135-54 284-81q-2-1-13-9.5t-16-13.5q-76-67-127-176q-27 86-83 197q-30 56-45 83m646-16q-24-24-140-24q76 28 124 28q14 0 18-1q0-1-2-3" />
                                                </svg><span> </span>Export To Pdf
                                            </a>
                                        </div>  *@
                                    </div>


                                </div>

                            </div>
                        </div>
                        <!--end row-->
                    </div>
                    <div class="col-12 col-lg-5 col-xl-5 ac-detail hide-sm" hidden>
                        <div class="card radius-10">
                            <div class="card-body" style="height:650px">
                                <h5 class="mb-0 mt-4">Supplier  Information</h5>
                                <hr>
                                <div class="row g-3 ac-detail d-none">
                                    <div class="col-6">
                                        <label class="form-label">Supplier Name</label>
                                        <input type="text" class="form-control" id="dspSupplierName" readonly>
                                        <input type="hidden" class="form-control" id="dspSupplierId" readonly>
                                        <input type="hidden" id="inputsiteId" value="@UserSession.SiteId" />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">Email</label>
                                        <input type="text" class="form-control" id="dspEmail" readonly>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">Phone</label>
                                        <input type="text" class="form-control" id="dspPhoneNo" readonly>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">Area</label>
                                        <input type="text" class="form-control" id="dspArea" readonly>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">BuildingName</label>
                                        <input type="text" class="form-control" id="dspBuildingName" readonly>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">State</label>
                                        <input type="text" class="form-control" id="dspStateName" readonly>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">City</label>
                                        <input type="text" class="form-control" id="dspCityName" readonly>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">PinCode</label>
                                        <input type="text" class="form-control" id="dspPinCode" readonly>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">BankName</label>
                                        <input type="text" class="form-control" id="dspBankName" readonly>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">AccountNo</label>
                                        <input type="text" class="form-control" id="dspAccountNo" readonly>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">Iffccode</label>
                                        <input type="text" class="form-control" id="dspIffccode" readonly>
                                    </div>
                                </div>
                                @* </form> *@
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="offcanvas offcanvas-end border-0 w-25 ac-add-edit" tabindex="-1" id="createSupplier" hidden>
        <div class="d-flex align-items-center bg-primary bg-gradient p-3 offcanvas-header">
            <h5 class="m-0 me-2 text-white">Create Supplier</h5>
            <button type="button" class="btn-close btn-close-white ms-auto" id="customizerclose-btn" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body p-0">
            <div data-simplebar class="h-100">
                <div class="p-4">
                    <div class="card">
                        <div class="card-body">
                            <form class="row g-3" id="SupplierForm">
                                <div class="col-md-12">
                                    <label class="form-label">Supplier Name</label>
                                    <input type="text" class="form-control" placeholder="Supplier Name" id="txtSupplierName" required>
                                    <span id="spnSupplier" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Phone Number</label>
                                    <input type="text" class="form-control" placeholder="Phone Number" id="txtPhoneNo" required>
                                    <span id="spnPhoneNo" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Email</label>
                                    <input type="text" class="form-control" placeholder="Email Address" id="txtEmail" required>
                                    <span id="spnEmail" class="text-danger"></span>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label">GST Number</label>
                                    <input type="text" class="form-control" placeholder="GST Number" id="txtGST" required>
                                    <span id="spnGST" class="text-danger"></span>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label">Building Name</label>
                                    <input type="text" class="form-control" placeholder="Building Name" id="txtBuilding" required>
                                    <span id="spnBuilding" class="text-danger"></span>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label">Area</label>
                                    <textarea type="text" class="form-control" rows="3" placeholder="Area" id="txtArea" required style="height: 75px;"></textarea>
                                    <span id="spnArea" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">PinCode</label>
                                    <input type="text" class="form-control" placeholder="PinCode" id="txtPinCode" required>
                                    <span id="spnPinCode" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">City</label>
                                    <select id="ddlCity" class="form-select bg-transparent">
                                        <option value="0">--Select City--</option>
                                    </select>
                                    <input type="hidden" id="txtcity" value="" />
                                    <span class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">State</label>
                                    <select id="dropState" class="form-select bg-transparent" onclick="fn_getcitiesbystateId('ddlCity',null,this)">
                                        <option value="0" selected>--Select State--</option>
                                    </select>
                                    <input type="hidden" id="txtstate" value="" />
                                    <span class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Country</label>
                                    <select id="ddlCountry" class="form-select bg-transparent" onchange="fn_getState('dropState',null,this)">
                                        <option>--Select Country--</option>
                                    </select>
                                    <span class="text-danger"></span>
                                </div>
                                <div class="col-12">
                                    <h5><b>Bank Details</b></h5>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Bank Name</label>
                                    <input type="text" class="form-control" placeholder="Bank Name" id="txtBank" required>
                                    <span id="spnBank" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Account Number</label>
                                    <input type="text" class="form-control" placeholder="Account Number" id="txtAccount" required>
                                    <span id="spnAccount" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">IFFC Code</label>
                                    <input type="text" class="form-control" placeholder="IFFC Code" id="txtIFFC" required>
                                    <span id="spnIFFC" class="text-danger"></span>
                                </div>
                                <div class="col-md-12">
                                    <button type="button" class="btn btn-lg btn-success col-lg-12" onclick="validateAndCreateSupplier()" id="btnuser">Submit</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
                        <script src="~/moduls/salesinvoicemasterscript.js" asp-append-version="true"></script>
}

