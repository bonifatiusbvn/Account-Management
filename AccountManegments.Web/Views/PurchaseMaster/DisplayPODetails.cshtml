@model AccountManagement.DBContext.Models.ViewModels.PurchaseOrder.PurchaseOrderMasterView
@inject IHttpContextAccessor Accessor;
@inject UserSession _userSession
@{
    ViewData["Title"] = "Purchase Order";
    Layout = "~/Views/Shared/Main_Layout.cshtml";
}

<style>
    .VerticalBorder {
        border-left: 2px solid lightgray;
        height: auto;
    }

    .Address-Details {
        display: flex;
        border: 1px solid lightgray;
        height: 155px;
    }

    th[colspan] {
        text-align: center;
    }

</style>

@{
    var firstItem = Model;
    decimal? totalAmount = 0;
    decimal? totalGst = 0;
}
<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="d-flex align-items-center">
    </div>
</div>
<div class="">
    <div class="">
        <div class=" radius-10 w-100">
            <div class="my-3 border-bottom"></div>
            <div class="">
                <div class="row justify-content-center">
                    <div class="col-xxl-9">
                        <div class="card">
                            <div class="row">
                                <div class="d-flex">
                                    <p style="margin-left: 455px; font-size:22px;"><b>Purchase Order</b></p>
                                </div>
                                <div class="card-body" id="cardbody1">
                                    <div class="d-flex">
                                        <div class="flex-grow-1 col-6" style="border: 1px solid lightgray;">
                                            <div class="flex-shrink-0 mt-sm-0 mt-3">
                                                <span class="text-muted" style="padding-left: 5px;"><b>@firstItem.CompanyName</b></span> <br />
                                                <span class="text-muted" style="padding-left: 5px; display: block;">@firstItem.BillingAddress</span>
                                                <span class="text-muted text-uppercase" style="padding-left: 5px;">GSTIN/UIN: @firstItem.CompanyGstno</span> <br />
                                                <span style="padding-left: 5px;">State Name: @firstItem.CompanyStateName, Code: @firstItem.CompanyStateCode</span>
                                            </div>

                                            <div style="border: 0px solid lightgray;border-width:0.5px;margin:0px;width:100%;"></div>
                                            <br />
                                            <div class="flex-shrink-0 mt-sm-0 mt-3">
                                                <p class="text-muted" style="padding-left: 5px;"><b>Consigner :</b></p>
                                                <span class="text-muted" style="padding-left: 5px;"><b>@firstItem.SupplierName</b></span><br />
                                                <span class="text-muted" style="padding-left: 5px;display: block;">@firstItem.SupplierFullAddress</span>
                                                <span class="text-muted text-uppercase" style="padding-left: 5px;">GSTIN/UIN :@firstItem.SupplierGstno</span><br />
                                                <span class="text-muted" style="padding-left: 5px;">State Name :@firstItem.SupplierStateName, Code  :@firstItem.SupplierStateCode</span>
                                            </div>
                                        </div>
                                        <div class="flex-grow-1 col-6" style="border: 1px solid lightgray;">
                                            <div class="row" style="position: relative;">
                                                <div class="col-6">
                                                    <div class="flex-shrink-0 mt-sm-0 mt-3">
                                                        <p class="text-muted" style="height: 15px;padding-left: 5px;">Purchase Order No.</p>
                                                        <p class="text-muted text-uppercase" style="height: 5px;padding-left: 5px;"><b>@Model.Poid</b></p>
                                                    </div>
                                                    <div style="border: 0px solid lightgray;border-width:0.5px;margin:0px;width:106%;"></div>
                                                    <div class="flex-shrink-0 mt-sm-0 mt-3">
                                                        <p class="text-muted" style="padding:4px;padding-left: 5px;height: 15px;">Contact Name</p>
                                                        <p class="text-muted text-uppercase" style="height: 5px;padding-left: 5px;"><b>@Model.ContactName</b></p>
                                                    </div>
                                                    <div style="border: 0px solid lightgray;border-width:0.5px;margin:0px;width:106%;"></div>
                                                    <div class="flex-shrink-0 mt-sm-0 mt-3">
                                                        <p class="text-muted" style="padding:4px;padding-left: 5px;height: 15px;">Dispatched By</p>
                                                        <p class="text-muted text-uppercase" style="height: 25px;padding-left: 5px;"><b>@Model.SupplierName</b></p>
                                                    </div>
                                                    <div style="border: 0px solid lightgray;border-width:0.5px;margin:0px;width:105%;"></div>
                                                    <div class="flex-shrink-0 mt-sm-0 mt-3">
                                                        <p class="text-muted" style="padding-left: 5px;">Mode / Terms of Payment</p>
                                                        <p class="text-muted text-uppercase" style="padding-left: 5px; height:35px;"><b></b></p>
                                                    </div>
                                                </div>

                                                <!-- Vertical line -->
                                                <div style="border-left: 2px solid lightgray; position: absolute; top: 0; bottom: 0; left: 50%;"></div>

                                                <div class="col-6">
                                                    <div class="flex-shrink-0 mt-sm-0 mt-3">
                                                        <p class="text-muted" style="height: 15px;">Dated</p>
                                                        <p class="text-muted text-uppercase" style="height: 15px;">
                                                            @{
                                                                string formattedDate = string.Empty;
                                                                if (!Model.Date.HasValue || Model.Date.Value == DateTime.MinValue)
                                                                {
                                                                    formattedDate = "";
                                                                }
                                                                else
                                                                {
                                                                    formattedDate = firstItem.Date?.ToString("dd-MMM-yy");
                                                                }
                                                            }
                                                            <b>@formattedDate</b>
                                                        </p>
                                                    </div>
                                                    <div style="border: 0px solid lightgray;border-width:0.5px;margin:-10px;width:104%;"></div>
                                                    <div class="flex-shrink-0 mt-sm-0 mt-3">
                                                        <p class="text-muted" style="padding:4px;padding-left: 0px;height: 15px;margin-top:10px;">Contact Number</p>
                                                        <p class="text-muted text-uppercase" style="height: 15px;"><b>@firstItem.ContactNumber</b></p>
                                                    </div>
                                                    <div style="border: 0px solid lightgray;border-width:0.5px;margin:-10px;width:104%;"></div>
                                                    <div class="flex-shrink-0 mt-sm-0 mt-3">
                                                        <p class="text-muted" style="padding:4px;padding-left: 0px;height: 15px;margin-top:10px;">Dispatched Through</p>
                                                        <p class="text-muted text-uppercase" style="height: 35px;"><b>@Model.DispatchBy</b></p>
                                                    </div>
                                                    <div style="border: 0px solid lightgray;border-width:0.5px;margin:-10px;width:104%;"></div>
                                                </div>
                                            </div>

                                        </div>
                                    </div>

                                    <div class="d-flex Address-Details">
                                        <div class="flex-grow-1 col-6">
                                            <p class="text-muted" style="padding-left: 5px;"><b>Consignee (Ship to):</b></p>
                                            <span class="text-muted" style="padding-left: 5px;"><b>@firstItem.SiteName</b></span><br />
                                            @foreach (var item in Model.AddressList)
                                            {
                                                if (!item.Address.StartsWith("Group-"))
                                                {
                                                    <span class="text-muted" style="padding-left: 5px; display: block;">
                                                        @item.Address
                                                    </span>
                                                }
                                            }
                                        </div>

                                        <div class="VerticalBorder"></div>

                                        <div class="flex-grow-1 col-6 no-top-border">
                                            <p class="text-muted" style="padding-left: 5px;"><b>Group Address :</b></p>
                                            <span class="text-muted" style="padding-left: 5px;"><b>@firstItem.SiteGroup</b></span><br />

                                            @foreach (var item in Model.AddressList)
                                            {
                                                if (item.Address.StartsWith("Group-"))
                                                {
                                                    <span class="text-muted" style="padding-left: 5px; display: block;">
                                                        @item.Address.Replace("Group-", "")
                                                    </span>
                                                }
                                            }

                                        </div>
                                    </div>

                                    <table class="table text-center align-middle manual_invoice-table" style="border: 1px solid lightgray; margin: 0;">
                                        <thead class="btn-primary text-muted">
                                            <tr class="table-active" style="border: 1px solid lightgray;">
                                                <th class="border" style="color:white;">Sr No.</th>
                                                <th class="border" style="color:white;">Product Details</th>
                                                <th class="border" style="color:white;">Quantity</th>
                                                <th class="border" style="color:white;">Rate</th>
                                                <th class="border" style="color:white;">Unit</th>
                                                <th class="border" style="color:white;">GST</th>
                                                <th class="border" style="color:white;">Amount</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @{
                                                int index = 1;
                                                decimal? totalprice = 0;
                                                decimal? totalAmt = 0;
                                                decimal? TotalQty = 0;
                                                decimal? cgst = 0;
                                                decimal? sgst = 0;
                                            }

                                            @foreach (var item in Model.ItemList)
                                            {
                                                totalprice = (item.Quantity * item.PricePerUnit);
                                                totalAmt += totalprice;
                                                TotalQty += item.Quantity;
                                                cgst = firstItem.TotalGstamount / 2;
                                                sgst = firstItem.TotalGstamount / 2;
                                                var trimmedUnitTypeName = item.UnitTypeName.Split('-').First().Trim();

                                                <tr>
                                                    <td class="border">@index</td>
                                                    <td class="text-center border">
                                                        <span class="fw-medium fw-semibold" id="txtproductname">@item.ItemName</span><br />
                                                        <span class="fw-medium text-muted" style="font-size:12px;">@item.ItemDescription</span>
                                                    </td>
                                                    <td class="border" id="txtper">@item.Quantity</td>
                                                    <td class="border" id="txtHSN">@item.PricePerUnit.ToString("N2")</td>
                                                    <td class="border" id="txtHSN">@trimmedUnitTypeName</td>
                                                    <td class="border" id="txtper">@item.GstPercentage</td>
                                                    <td class="border" id="txttotal">₹@($"{item.Quantity * item.PricePerUnit:N2}")</td>
                                                </tr>
                                                index++;
                                            }
                                            <tr>
                                                <td class="border"></td>
                                                <td class="border" style="text-align: end;">CGST</td>
                                                <td class="border"></td>
                                                <td class="border"></td>
                                                <td class="border" style="text-align: end;"></td>
                                                <td class="border" style="text-align: start;"></td>
                                                <td class="border"><b>₹@($"{cgst:N2}")</b></td>
                                            </tr>
                                            <tr>
                                                <td class="border"></td>
                                                <td class="border" style="text-align: end;">SGST</td>
                                                <td class="border"></td>
                                                <td class="border"></td>
                                                <td class="border" style="text-align: end;"></td>
                                                <td class="border" style="text-align: start;"></td>
                                                <td class="border"><b>₹@($"{sgst:N2}")</b></td>
                                            </tr>
                                            <tr>
                                                <td class="border"></td>
                                                <td class="text-end border">Total</td>
                                                <td class="border">@TotalQty</td>
                                                <td class="border"></td>
                                                <td class="border"></td>
                                                <td class="border"></td>
                                                <td class="border"><b>₹@firstItem.TotalAmount.ToString("N2")</b></td>
                                            </tr>
                                        </tbody>
                                    </table><!--end table-->
                                    <div class="flex-grow-1 col-12" style="border: 1px solid lightgray;">
                                        <span class="text-muted">Amount Chargeable (in words)<i style="margin-left: 905px" ;>E. &amp; O.E</i></span><br />
                                        <p class="text-muted text-capitalize"><b>INR @ViewData["TotalAmountInWords"]</b></p>
                                    </div>
                                    @{
                                        var groupedItems = Model.ItemList
                                        .GroupBy(item => new { StateTaxPer = item.GstPercentage / 2, CenteralTaxPer = item.GstPercentage / 2 })
                                        .Select(group => new
                                        {
                                            Hsncode = group.First().Hsncode,
                                            TaxableValue = group.Sum(item => item.Quantity * item.PricePerUnit),
                                            StateTaxPer = group.Key.StateTaxPer,
                                            StateTax = Math.Round(group.Sum(item => item.Quantity * item.PricePerUnit * group.Key.StateTaxPer / 100).GetValueOrDefault(), 2),
                                            CenteralTaxPer = group.Key.CenteralTaxPer,
                                            CenteralTax = Math.Round(group.Sum(item => item.Quantity * item.PricePerUnit * group.Key.CenteralTaxPer / 100).GetValueOrDefault(), 2),
                                            GstAmount = group.Sum(item => item.Gstamount ?? 0)
                                        }).ToList();

                                        decimal? taxTotal = groupedItems.Sum(item => item.TaxableValue);
                                        decimal? TotalCenteralTax = groupedItems.Sum(item => item.CenteralTax);
                                        decimal? TotalStateTax = groupedItems.Sum(item => item.StateTax);
                                        decimal? TotalGSTAmount = TotalCenteralTax + TotalStateTax;
                                    }

                                    <table class="table text-center align-middle invoice-table" style="border: 1px solid lightgray;">
                                        <thead class="btn-primary">
                                            <tr class="table-active" style="color:white;">
                                                <th rowspan="2">HSN/SAC</th>
                                                <th rowspan="2">Taxable<br /> Value</th>
                                                <th colspan="2">Central Tax</th>
                                                <th colspan="2">State Tax</th>
                                                <th rowspan="2">Total<br /> Tax Amount</th>
                                            </tr>
                                            <tr class="table-active" style="color:white;">
                                                <th>Rate</th>
                                                <th>Amount</th>
                                                <th>Rate</th>
                                                <th>Amount</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in groupedItems)
                                            {
                                                <tr>
                                                    <td class="border">@item.Hsncode</td>
                                                    <td class="border">₹@item.TaxableValue.ToString("N2")</td>
                                                    <td class="border">@item.CenteralTaxPer%</td>
                                                    <td class="border">₹@item.CenteralTax.ToString("N2")</td>
                                                    <td class="border">@item.StateTaxPer%</td>
                                                    <td class="border">₹@item.StateTax.ToString("N2")</td>
                                                    <td class="border"><b>₹@TotalGSTAmount?.ToString("N2")</b></td>
                                                </tr>
                                            }
                                            <tr>
                                                <td class="text-end border">Total</td>
                                                <td class="border"><b>₹@taxTotal?.ToString("N2")</b></td>
                                                <td class="border"></td>
                                                <td class="border"><b>₹@TotalCenteralTax?.ToString("N2")</b></td>
                                                <td class="border"></td>
                                                <td class="border"><b>₹@TotalStateTax?.ToString("N2")</b></td>
                                                <td class="border"><b>₹@TotalGSTAmount?.ToString("N2")</b></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                    <!--end table-->
                                    <div class="flex-grow-1 col-12" style="border: 1px solid lightgray; margin: 0;">
                                        <span class="text-muted">Tax Amount (in words) :<i style="margin-left: 870px;">E. &amp; O.E</i></span><br />
                                        <p class="text-muted text-capitalize"><b>INR @ViewData["TotalGstInWords"]</b></p>

                                        <div class="row d-flex" style="position: relative;">
                                            <div class="col-6">
                                                @if (firstItem.PaymentTerms != null)
                                                {
                                                    <div style="border: 1px solid lightgray; padding: 10px; margin-top: 10px;">
                                                        <span class="text-muted">@Html.Raw(firstItem.PaymentTerms)</span>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="text-muted"><u></u></span>
                                                    <span class="text-muted"></span>
                                                }
                                            </div>
                                            <div class="col-6 d-flex align-items-end">
                                                <div class="text-end p-1" style="border: 1px solid lightgray; height:100px; width:578px;">
                                                    <p class="text-muted"><b>for @firstItem.CompanyName</b></p>
                                                    <p class="text-muted" style="margin-top:45px;">Authorised Signatory</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                                <div class="d-flex">
                                    <p style="margin-left: 400px;">This is a Computer Generated Purchase Order</p>
                                </div>
                            </div>
                        </div>

                        <div class="card d-print-none">
                            <div class="card-body">
                                <div class="d-lg-flex align-items-center gap-3">

                                    @if (UserSession.FormPermisionData.Any(a => a.FormName == "Purchase Orders" && (a.Edit == true)))
                                    {
                                        <a class="btn btn-primary btn-ecomm" id="EditPOButton" href="DisplayPurchaseOrderDetails?Id=@Model.Id" title="Edit" aria-label="Edit"><i class="fadeIn animated bx bx-edit"></i>Edit</a>
                                    }
                                    @if (Model.SupplierName == "JK LAKSHMI CEMENT LTD")
                                    {
                                        <a class="btn btn-primary btn-ecomm" id="PrintJKPOPage"><i class="fadeIn animated bx bx-printer"></i>Print</a>
                                    }
                                    else if (Model.SupplierName == "ULTRATECH CEMENT LIMITED-AMBIKA" || Model.SupplierName == "ULTRATECH CEMENT LIMITED-SHIVAM" || Model.SupplierName == "HI BOND CEMENT INDIA PVT LTD.  -SHREE HARSIDDHI ENTERPRISE")
                                    {
                                        <a class="btn btn-primary btn-ecomm" id="PrintUltra"><i class="fadeIn animated bx bx-printer"></i>Print</a>
                                    }
                                    else
                                    {
                                        <a class="btn btn-primary btn-ecomm" id="PrintPOPage"><i class="fadeIn animated bx bx-printer"></i>Print</a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/moduls/purchaserequestscript.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const printPOButton = document.getElementById('PrintPOPage');
            const printJKPOButton = document.getElementById('PrintJKPOPage');
            const printUltraPOButton = document.getElementById('PrintUltra');
            const POId = '@firstItem.Id';

            if (printPOButton) {
                printPOButton.addEventListener('click', function () {
                    fetch(`/PurchaseMaster/PrintPODetails?POId=${POId}`)
                        .then(response => {
                            if (!response.ok) {
                                throw new Error('Network response was not ok');
                            }
                            return response.text();
                        })
                        .then(htmlContent => {
                            const printWindow = window.open('', '', 'width=800,height=600');
                            if (printWindow) {
                                printWindow.document.open();
                                printWindow.document.write(htmlContent);
                                printWindow.document.close();

                            } else {
                                console.error('Failed to open new window.');
                            }
                        })
                        .catch(error => console.error('Error fetching the invoice details:', error));
                });
            }

            if (printJKPOButton) {
                printJKPOButton.addEventListener('click', function () {
                    fetch(`/PurchaseMaster/JKDetails?POId=${POId}`)
                        .then(response => {

                            if (!response.ok) {
                                throw new Error('Network response was not ok');
                            }
                            return response.text();
                        })
                        .then(htmlContent => {

                            const printWindow = window.open('', '', 'width=800,height=600');
                            if (printWindow) {
                                printWindow.document.open();
                                printWindow.document.write(htmlContent);
                                printWindow.document.close();

                            } else {
                                console.error('Failed to open new window.');
                            }
                        })
                        .catch(error => console.error('Error fetching the invoice details:', error));
                });
            }
            if (printUltraPOButton) {
                printUltraPOButton.addEventListener('click', function () {
                    fetch(`/PurchaseMaster/PurchaseUltraDetails?POId=${POId}`)
                        .then(response => {
                            if (!response.ok) {
                                throw new Error('Network response was not ok');
                            }
                            return response.text();
                        })
                        .then(htmlContent => {
                            const printWindow = window.open('', '', 'width=800,height=600');
                            if (printWindow) {
                                printWindow.document.open();
                                printWindow.document.write(htmlContent);
                                printWindow.document.close();

                            } else {
                                console.error('Failed to open new window.');
                            }
                        })
                        .catch(error => console.error('Error fetching the invoice details:', error));
                });
            }
        });
    </script>
}
